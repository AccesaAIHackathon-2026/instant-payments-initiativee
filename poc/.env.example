# Copy to .env and fill in values. Never commit .env.

# API key required on all /bank/** requests
BANK_API_KEY=blinkpay-poc-key

# Host IP reachable from the Android device
# Emulator : http://10.0.2.2:8080
# Physical device (LAN)  : http://192.168.x.x:8080
# Physical device (VPN)  : http://<vpn-ip>:8080
BANK_API_BASE_URL=http://10.0.2.2:8080
